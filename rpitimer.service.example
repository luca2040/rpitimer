[Unit]
Description=rpitimer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/user/rpitimer/src/main.py
Restart=always
RestartSec=2
User=user
WorkingDirectory=/home/user/rpitimer/src/
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
